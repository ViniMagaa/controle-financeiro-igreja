generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id           String        @id @default(uuid())
  name         String        @unique
  transactions Transaction[]
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("categories")
}

model Supplier {
  id           String        @id @default(uuid())
  name         String        @unique
  transactions Transaction[]
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("suppliers")
}

model Transaction {
  id              String          @id @default(uuid())
  type            TransactionType
  description     String?
  amount          Decimal         @db.Decimal(10, 2)
  date            DateTime        @db.Date
  responsibleName String          @map("responsible_name")
  paymentMethod   PaymentMethod   @map("payment_method")
  attachmentUrl   String?         @map("attachment_url")
  invoiceUrl      String?         @map("invoice_url")
  categoryId      String          @map("category_id")
  category        Category        @relation(fields: [categoryId], references: [id])
  supplierId      String?         @map("supplier_id")
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])

  // Auto-relação para transações vinculadas
  linkedTransactionId String?      @unique @map("linked_transaction_id")
  linkedTransaction   Transaction? @relation("LinkedTransactions", fields: [linkedTransactionId], references: [id], onDelete: SetNull)
  linkedBy            Transaction? @relation("LinkedTransactions")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  pix
  cash
  card
  boleto
  transfer
}
